{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/workspace",
      "destination": "/workspace.html"
    },
    {
      "source": "/app",
      "destination": "/workspace.html"
    }
  ]
}
